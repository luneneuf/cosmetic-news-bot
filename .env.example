# cosmetic-news-bot 로컬 실행용 환경변수 예시
# 실제 값을 채운 뒤 .env 로 복사하거나, Windows 사용자 환경변수로 등록

# GitHub Actions에서는 secrets.*로 주입됨 — 로컬에서만 직접 설정 필요

# Naver News API (collect_and_post.py)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# OpenAI (collect_and_post.py, briefing.py)
OPENAI_API_KEY=

# Slack Incoming Webhooks
SLACK_WEBHOOK_URL=              # #cosmetic-news 채널 (collect_and_post.py)
BRIEFING_SLACK_WEBHOOK_URL=     # #cosmetic-briefing 채널 (briefing.py)
LAKA_SAFETY_SLACK_WEBHOOK_URL=  # #qa-인허가-법규 채널 (safety_signals_slack.py, LAKA 워크스페이스)
